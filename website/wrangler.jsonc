{
  "$schema": "./node_modules/wrangler/config-schema.json",
  // Cloudflare Pages: use `wrangler pages deploy`, never `wrangler deploy` (that is for Workers only).
  // `name` must match your Pages project in the dashboard.
  "compatibility_date": "2026-03-24",
  "name": "pragmatic",
  "assets": {
    "directory": "./dist",
  },
}
